# General
JBOT_MESSENGER=discord
JBOT_TIMEZONE=US/Pacific
JBOT_TAG_UNANSWERED_PLAYERS=False

# Features
JBOT_ENABLE_SEASONS=True

# Seasons Configuration (only used if JBOT_ENABLE_SEASONS=True)
# Season mode: "calendar" for monthly seasons, "rolling" for fixed N-day periods
JBOT_SEASON_MODE=calendar
# Duration in days (only used if JBOT_SEASON_MODE=rolling)
JBOT_SEASON_DURATION_DAYS=30
# Automatically create new seasons
JBOT_SEASON_AUTO_CREATE=True
# Number of trophy positions (1st, 2nd, 3rd)
JBOT_SEASON_TROPHY_POSITIONS=3
# Announce season end in channel
JBOT_SEASON_ANNOUNCE_END=True
# Announce new season start
JBOT_SEASON_ANNOUNCE_START=True
# Days before end to remind about season ending
JBOT_SEASON_REMINDER_DAYS=3

# Question Sources
# All question sources are configured in sources.toml
JBOT_QUESTION_RETRIES=10
# Number of days to look back for duplicate riddle prevention
JBOT_RIDDLE_HISTORY_DAYS=90

# Discord
JBOT_DISCORD_BOT_TOKEN=todo

# Roles
JBOT_FIRST_PLACE_ROLE_NAME="first place"
JBOT_PLAYER_ROLE_NAME="players"

# Database
JBOT_DB_PATH=db/jbot.db

# Schedule
JBOT_MORNING_TIME=8:00
JBOT_REMINDER_TIME=19:00
JBOT_EVENING_TIME=20:00

# Gemini
# https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=todo
GEMINI_MODEL=gemini-2.5-pro

# Bonus Points
JBOT_BONUS_STREAK_PER_DAY=5
JBOT_BONUS_STREAK_CAP=25
JBOT_BONUS_BEFORE_HINT=10
# Fastest Bonuses CSV (e.g. 10,5,1 for 1st/2nd/3rd)
JBOT_BONUS_FASTEST_CSV="10,5,1"
# Try/Guess Bonuses CSV (e.g. 20,10,5 for 1st/2nd/3rd)
JBOT_BONUS_TRY_CSV="20,10,5"
# Score multiplier awarded the next day after a player uses /power rest
JBOT_REST_MULTIPLIER=1.2
JBOT_STEAL_STREAK_COST=2
# Retroactive powerup costs (applied when the target already answered correctly)
JBOT_RETRO_STEAL_STREAK_COST=4
JBOT_RETRO_JINX_BONUS_RATIO=0.5

# Emojis
JBOT_EMOJI_FASTEST="🥇"
JBOT_EMOJI_FASTEST_CSV="🥇,🥈,🥉"
JBOT_EMOJI_FIRST_TRY="🎯"
JBOT_EMOJI_STREAK="🔥"
JBOT_EMOJI_STREAK_BROKEN="💔"
JBOT_EMOJI_BEFORE_HINT="🧠"
JBOT_EMOJI_JINXED="🧙"
JBOT_EMOJI_SILENCED="🤐"
JBOT_EMOJI_STOLEN_FROM="💸"
JBOT_EMOJI_STEALING="💰"
JBOT_EMOJI_REST="😴"
JBOT_EMOJI_REST_WAKEUP="⏰"
GEMINI_MODEL=gemini-2.5-pro
